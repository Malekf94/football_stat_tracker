# Virtual environment
venv/

# Downloaded model weights (auto-downloaded on first run)
*.pt

# Generated outputs
output/

# Python bytecode
__pycache__/
*.pyc

# Ultralytics run logs
runs/

# Training dataset: keep the hand-corrected labels + data.yaml (the real work),
# but not the 67 MB of sampled frames (regeneratable via make_dataset.py) or the
# ultralytics label cache.
dataset/images/
*.cache

# Defensive-action video clips (regeneratable from labels via make_defense_dataset.py)
dataset_defense/
# Trained defensive-action model weights (large; regeneratable via train_defense.py)
runs_defense/
